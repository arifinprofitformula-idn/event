NODE_ENV=production
PORT=3000
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_NAME=Administrator
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=replace-with-a-strong-initial-password
SESSION_HOURS=8
